    "team_pcba": {
      "title": "团队：PCBA 设计",
      "subtitle": "AC792N 原理图与 4 层 PCB 布局",
      "scope_title": "工作范围",
      "scopes": [
        {
          "heading": "1. 电源树",
          "items": [
            "AC792N 需要：DVDD33（3.3V）、DVDD12（1.2V）、DCVDD14/WFVDD14（1.4V DCDC）",
            "电池：22,000mAh 锂离子，含电量计 IC",
            "USB-C PD：充电输入 + 移动设备充电输出",
            "Qi 无线充电线圈：与 DCDC 电感隔离（>30mm 或铁镍合金屏蔽）"
          ]
        },
        {
          "heading": "2. 音频走线",
          "items": [
            "AC792N DAC 输出 → D 类放大器 → 扬声器",
            "模拟地平面隔离 — 模拟区域下方不走数字线",
            "严格遵循 AC792N 数据手册 4.5 和 4.6 节"
          ]
        },
        {
          "heading": "3. 晶振与时钟",
          "items": [
            "24MHz 主晶振：±10ppm 公差（第 2.2 节）",
            "32.768kHz RTC 晶振：±10ppm 公差，用于计时",
            "布局：距 AC792N 5mm 以内，走线尽量短"
          ]
        }
      ],
      "deliverables_title": "交付物",
